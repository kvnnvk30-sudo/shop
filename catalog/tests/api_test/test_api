from django.test import TestCase
from django.urls import reverse
from django.contrib.auth.models import User
from catalog.models import Item

class TestHome(TestCase):
    def setUp(self):
        self.user = User.objects.create_user(username='Nick', password='grop9302')
        self.item = Item.objects.create(title='car', price=15.00, is_available=True)
        self.response = self.client.get(reverse('catalog:home')) # Отлично!

    def test_home(self):
        self.assertEqual(self.response.status_code, 200) 

    def test_home_contains(self):
        self.assertContains(self.response, 'car')

    def test_home_uses_correct(self):
        self.assertTemplateUsed(self.response, 'catalog/home.html')


class LoginViewTest(TestCase):
    def setUp(self):
        self.user = User.objects.create_user(username='Nick', password='grop9302')
        # Сохраняем в setUp только GET-запрос (отображение страницы)
        self.response = self.client.get(reverse('catalog:login'))

    def test_login_page_returns_200(self):
        self.assertEqual(self.response.status_code, 200)
        
    def test_login_with_correct_credentials(self):
        # Переносим ПОСТ-запрос сюда и передаем данные Ника
        response = self.client.post(reverse('catalog:login'), {
            'username': 'Nick',
            'password': 'grop9302'
        })
        self.assertRedirects(response, reverse('catalog:home'))

    def test_login_with_wrong_password(self):
        response = self.client.post(reverse('catalog:login'), {
            'username': 'Nick',
            'password': 'wrongpassword'
        })
        self.assertEqual(response.status_code, 200)
        # Если используешь стандартный Django LoginView, не забудь поменять 
        # фразу ниже на стандартную джанговскую (длинную), иначе упадет.
        self.assertContains(response, 'Неверный логин или пароль')


class RegisterViewTest(TestCase):
    def setUp(self):
        self.response = self.client.get(reverse('catalog:register'))

    def test_register_page_returns_200(self):
        self.assertEqual(self.response.status_code, 200)

    def test_register_creates_user(self):
        response = self.client.post(reverse('catalog:register'), {
            'username': 'newuser',
            'email': 'new@test.com',
            'password1': 'ComplexPass123!',
            'password2': 'ComplexPass123!'
        })
        self.assertEqual(response.status_code, 302)
        self.assertTrue(User.objects.filter(username='newuser').exists())

    def test_register_redirects_after_success(self):
        response = self.client.post(reverse('catalog:register'), {
            'username': 'newuser2',
            'email': 'new2@test.com',
            'password1': 'ComplexPass123!',
            'password2': 'ComplexPass123!'
        })
        self.assertRedirects(response, reverse('catalog:home'))


class LogoutViewTest(TestCase):
    def setUp(self):
        self.user = User.objects.create_user(username='testuser', password='testpass123')
        self.client.login(username='testuser', password='testpass123')

    def test_logout_redirects(self):
        """Выход редиректит на главную"""
        # Делаем запрос на выход именно внутри теста
        response = self.client.post(reverse('catalog:logout'))
        self.assertRedirects(response, reverse('catalog:home'))